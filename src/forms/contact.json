{
  "version": "1",
  "actions": {
    "trackFormStart": {
      "body": "if (typeof window !== 'undefined' && window.dataLayer && !window.__contactFormStartTracked) {\n  window.__contactFormStartTracked = true;\n  window.dataLayer.push({\n    'event': 'contact_form_start',\n    'form_id': 'contact_form',\n    'timestamp': new Date().toISOString()\n  });\n}",
      "params": {}
    },
    "sendForm": {
      "body": "    const rootComponent = e.store.form.componentTree\n\n    const setVisible = (key, visible) => {\n        const componentStore = rootComponent.findByKey(key)?.store\n        if (componentStore) {\n            componentStore.renderWhen = {value: visible}\n        }\n    }\n\n    const setUserProps = (key, userProps) => {\n        const component = rootComponent.findByKey(key)\n        if (!component) return\n        component.userDefinedProps = userProps\n    }\n\n    setVisible('errorMessage', false)\n    setVisible('successMessage', false)\n\n    if (rootComponent.hasErrors) return\n\n    setUserProps('contact_container', {disabled: true})\n    \n    try {\n        const backendUrl = window.location.hostname.includes('netlify') ? '/.netlify/functions/lead' : '/backend/lead/';\n        const response = await fetch(backendUrl, {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/json'\n            },\n            body: JSON.stringify(e.data)\n        })\n        \n        if (!response.ok) {\n            // GTM Error Tracking\n            if (typeof window !== 'undefined' && window.dataLayer) {\n                window.dataLayer.push({\n                    'event': 'contact_form_submit_error',\n                    'form_id': 'contact_form',\n                    'error_type': 'http_error',\n                    'error_code': response.status,\n                    'timestamp': new Date().toISOString()\n                });\n            }\n            setUserProps('contact_container', {disabled: false})\n            setVisible('errorMessage', true)\n            return\n        }\n\n        await response.json()\n        \n        // GTM Success Tracking\n        if (typeof window !== 'undefined' && window.dataLayer) {\n            window.dataLayer.push({\n                'event': 'contact_form_submit_success',\n                'form_id': 'contact_form',\n                'timestamp': new Date().toISOString()\n            });\n        }\n        \n        setVisible('contact_container', false)\n        setVisible('successMessage', true)\n    } catch (e) {\n        // GTM Network Error Tracking\n        if (typeof window !== 'undefined' && window.dataLayer) {\n            window.dataLayer.push({\n                'event': 'contact_form_submit_error',\n                'form_id': 'contact_form',\n                'error_type': 'network_error',\n                'timestamp': new Date().toISOString()\n            });\n        }\n        setUserProps('contact_container', {disabled: false})\n        setVisible('errorMessage', true)\n    }",
      "params": {}
    }
  },
