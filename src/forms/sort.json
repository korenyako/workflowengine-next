{
    "version": "1",
    "actions": {
      "handleSortColumn": {
        "body": "  const [sortColumn, sortType] = e.args\n\n  const sort = (data) => {\n    if (sortColumn && sortType) {\n      return data.sort((a, b) => {\n        let x = a[sortColumn];\n        let y = b[sortColumn];\n        if (typeof x === 'string') {\n          x = x.charCodeAt();\n        }\n        if (typeof y === 'string') {\n          y = y.charCodeAt();\n        }\n        if (sortType === 'asc') {\n          return x - y;\n        } else {\n          return y - x;\n        }\n      });\n    }\n    return data;\n  };\n\n  e.setUserDefinedProps({...e.userDefinedProps, loading: true})\n\n  setTimeout(() => {\n    const currentData = JSON.parse(JSON.stringify(e.sender.field?.value ?? []))\n    const data = sort(currentData)\n\n    e.setUserDefinedProps({\n      ...e.userDefinedProps,\n      loading: false,\n      data,\n      sortColumn,\n      sortType\n    })\n  }, 500);",
        "params": {}
      }
    },
