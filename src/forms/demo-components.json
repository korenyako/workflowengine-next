{
  "version": "1",
  "tooltipType": "RsTooltip",
  "errorType": "RsErrorMessage",
  "form": {
    "key": "Screen",
    "type": "Screen",
    "props": {},
    "children": [
      {
        "key": "row1",
        "type": "RsContainer",
        "props": {},
        "css": { "any": { "string": "display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px;" } },
        "children": [
          {
            "key": "website",
            "type": "RsInput",
            "props": {
              "label": { "value": "Website" },
              "placeholder": { "value": "www.example.com" }
            }
          },
          {
            "key": "company",
            "type": "RsInput",
            "props": {
              "label": { "value": "Company" },
              "placeholder": { "value": "Acme Inc." }
            }
          },
          {
            "key": "uploader",
            "type": "RsUploader",
            "props": {
              "label": { "value": "Upload Document" },
              "draggable": { "value": true },
              "action": { "value": "" },
              "accept": { "value": ".pdf,.jpg,.png" }
            }
          }
        ]
      },
      {
        "key": "row2",
        "type": "RsContainer",
        "props": {},
        "css": { "any": { "string": "display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px;" } },
        "children": [
          {
            "key": "about",
            "type": "RsTextArea",
            "props": {
              "label": { "value": "About" },
              "placeholder": { "value": "Tell us about yourself..." },
              "rows": { "value": 4 }
            }
          },
          {
            "key": "col2_mid",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "display: flex; flex-direction: column; gap: 12px;" } },
            "children": [
              {
                "key": "email",
                "type": "RsInput",
                "props": {
                  "label": { "value": "Email" },
                  "placeholder": { "value": "user@company.com" }
                },
                "schema": {
                  "autoValidate": true,
                  "validations": [
                    { "key": "email", "args": { "message": "Invalid email format" } }
                  ]
                }
              },
              {
                "key": "autocomplete",
                "type": "RsAutoComplete",
                "props": {
                  "label": { "value": "Country" },
                  "placeholder": { "value": "Start typing..." },
                  "data": { "value": ["Afghanistan", "Albania", "Algeria", "Argentina", "Armenia", "Australia", "Austria", "Azerbaijan", "Bangladesh", "Belarus", "Belgium", "Bolivia", "Brazil", "Bulgaria", "Cambodia", "Canada", "Chile", "China", "Colombia", "Costa Rica", "Croatia", "Cuba", "Cyprus", "Czech Republic", "Denmark", "Dominican Republic", "Ecuador", "Egypt", "Estonia", "Ethiopia", "Finland", "France", "Georgia", "Germany", "Ghana", "Greece", "Guatemala", "Hungary", "Iceland", "India", "Indonesia", "Iran", "Iraq", "Ireland", "Israel", "Italy", "Jamaica", "Japan", "Jordan", "Kazakhstan", "Kenya", "Kuwait", "Latvia", "Lebanon", "Lithuania", "Luxembourg", "Malaysia", "Mexico", "Moldova", "Mongolia", "Morocco", "Nepal", "Netherlands", "New Zealand", "Nigeria", "North Korea", "Norway", "Oman", "Pakistan", "Panama", "Paraguay", "Peru", "Philippines", "Poland", "Portugal", "Qatar", "Romania", "Russia", "Saudi Arabia", "Serbia", "Singapore", "Slovakia", "Slovenia", "South Africa", "South Korea", "Spain", "Sri Lanka", "Sweden", "Switzerland", "Syria", "Taiwan", "Thailand", "Tunisia", "Turkey", "Ukraine", "United Arab Emirates", "United Kingdom", "United States", "Uruguay", "Uzbekistan", "Venezuela", "Vietnam"] }
                }
              }
            ]
          },
          {
            "key": "col2_right",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "display: flex; flex-direction: column; gap: 12px;" } },
            "children": [
              {
                "key": "birthDate",
                "type": "RsDatePicker",
                "props": {
                  "label": { "value": "Birth Date" },
                  "placeholder": { "value": "Select date" },
                  "oneTap": { "value": true }
                }
              },
              {
                "key": "tags",
                "type": "RsTagPicker",
                "props": {
                  "label": { "value": "Skills" },
                  "placeholder": { "value": "Select skills" },
                  "data": { "value": [
                    { "value": "react", "label": "React" },
                    { "value": "typescript", "label": "TypeScript" },
                    { "value": "nextjs", "label": "Next.js" },
                    { "value": "nodejs", "label": "Node.js" },
                    { "value": "python", "label": "Python" },
                    { "value": "graphql", "label": "GraphQL" },
                    { "value": "docker", "label": "Docker" },
                    { "value": "aws", "label": "AWS" }
                  ] },
                  "defaultValue": { "value": ["react", "typescript"] }
                }
              }
            ]
          }
        ]
      },
      {
        "key": "row3",
        "type": "RsContainer",
        "props": {},
        "css": { "any": { "string": "display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px; align-items: center;" } },
        "children": [
          {
            "key": "col3_left",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "display: flex; flex-direction: column; gap: 12px;" } },
            "children": [
              {
                "key": "back_btn",
                "type": "RsButton",
                "props": {
                  "children": { "value": "← Back" },
                  "appearance": { "value": "ghost" }
                }
              },
              {
                "key": "disabled_btn",
                "type": "RsButton",
                "props": {
                  "children": { "value": "Disabled" },
                  "disabled": { "value": true },
                  "appearance": { "value": "default" }
                }
              },
              {
                "key": "save_btn",
                "type": "RsButton",
                "props": {
                  "children": { "value": "Save" },
                  "color": { "value": "blue" },
                  "appearance": { "value": "primary" }
                }
              }
            ]
          },
          {
            "key": "col3_mid",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "display: flex; flex-direction: column; gap: 12px;" } },
            "children": [
              {
                "key": "option",
                "type": "RsRadioGroup",
                "props": {
                  "label": { "value": "Plan" },
                  "items": { "value": [
                    { "value": "free", "label": "Free" },
                    { "value": "pro", "label": "Pro" },
                    { "value": "enterprise", "label": "Enterprise" }
                  ] },
                  "defaultValue": { "value": "pro" },
                  "inline": { "value": true }
                }
              },
              {
                "key": "agree",
                "type": "RsCheckbox",
                "props": {
                  "label": { "value": "I agree to Terms" }
                }
              },
              {
                "key": "remember",
                "type": "RsToggle",
                "props": {
                  "label": { "value": "Remember me" }
                }
              }
            ]
          },
          {
            "key": "col3_right",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "display: flex; flex-direction: column; gap: 12px;" } },
            "children": [
              {
                "key": "progressCircle",
                "type": "RsProgressCircle",
                "props": {
                  "percent": { "value": 75 },
                  "status": { "value": "active" }
                },
                "css": { "any": { "string": "width: 80px;" } }
              },
              {
                "key": "progress",
                "type": "RsProgressLine",
                "props": {
                  "percent": { "value": 65 },
                  "status": { "value": "active" }
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "localization": {},
  "languages": [
    {
      "code": "en",
      "dialect": "US",
      "name": "English",
      "description": "American English",
      "bidi": "ltr"
    }
  ],
  "defaultLanguage": "en-US"
}
