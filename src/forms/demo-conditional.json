{
  "version": "1",
  "tooltipType": "RsTooltip",
  "errorType": "RsErrorMessage",
  "form": {
    "key": "Screen",
    "type": "Screen",
    "props": {},
    "children": [
      {
        "key": "row1",
        "type": "RsContainer",
        "props": {},
        "css": { "any": { "string": "display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px;" } },
        "children": [
          {
            "key": "card1",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "background: #ffffff; border-radius: 12px; padding: 24px; min-height: 280px;" } },
            "children": [
              {
                "key": "card1_label",
                "type": "RsLabel",
                "props": {
                  "text": { "value": "What were your reasons for cancelling?" }
                }
              },
              {
                "key": "noNeed",
                "type": "RsCheckbox",
                "props": {
                  "children": { "value": "No longer need it" }
                }
              },
              {
                "key": "quality",
                "type": "RsCheckbox",
                "props": {
                  "children": { "value": "Quality was less than expected" }
                }
              },
              {
                "key": "feedback",
                "type": "RsTextArea",
                "props": {
                  "label": { "value": "What can we do to make your experience more satisfying?" },
                  "placeholder": { "value": "Enter text" },
                  "rows": { "value": 3 }
                },
                "renderWhen": { "value": "form.data.quality === true" }
              }
            ]
          },
          {
            "key": "card2",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "background: #ffffff; border-radius: 12px; padding: 24px; min-height: 280px;" } },
            "children": [
              {
                "key": "propertyUse",
                "type": "RsRadioGroup",
                "props": {
                  "label": { "value": "Is this property to be used for?" },
                  "items": { "value": [
                    { "value": "residential", "label": "Residential" },
                    { "value": "holiday", "label": "Holiday let" }
                  ] }
                }
              },
              {
                "key": "holidayQuestion",
                "type": "RsDropdown",
                "props": {
                  "label": { "value": "If this is an application for a holiday let, do you intend to personally use the property for more than 60 days per annum?" },
                  "placeholder": { "value": "Please select" },
                  "data": { "value": [
                    { "value": "yes", "label": "Yes" },
                    { "value": "no", "label": "No" }
                  ] }
                },
                "renderWhen": { "value": "form.data.propertyUse === 'holiday'" }
              }
            ]
          },
          {
            "key": "card3",
            "type": "RsContainer",
            "props": {},
            "css": { "any": { "string": "background: #ffffff; border-radius: 12px; padding: 24px; min-height: 280px;" } },
            "children": [
              {
                "key": "card3_label",
                "type": "RsLabel",
                "props": {
                  "text": { "value": "Have you ever had any of the following?" }
                }
              },
              {
                "key": "problem",
                "type": "RsDropdown",
                "props": {
                  "label": { "value": "Problem" },
                  "placeholder": { "value": "Select" },
                  "data": { "value": [
                    { "value": "back", "label": "Back problems" },
                    { "value": "heart", "label": "Heart condition" },
                    { "value": "joint", "label": "Joint problems" },
                    { "value": "none", "label": "None of the above" }
                  ] }
                }
              },
              {
                "key": "surgeryDetails",
                "type": "RsTextArea",
                "props": {
                  "label": { "value": "Indicate whether you have ever had a surgery related to the problem" },
                  "placeholder": { "value": "Enter text" },
                  "rows": { "value": 3 }
                },
                "renderWhen": { "value": "form.data.problem && form.data.problem !== 'none'" }
              }
            ]
          }
        ]
      }
    ]
  },
  "localization": {},
  "languages": [
    {
      "code": "en",
      "dialect": "US",
      "name": "English",
      "description": "American English",
      "bidi": "ltr"
    }
  ],
  "defaultLanguage": "en-US"
}
